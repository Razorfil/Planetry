export interface PlanetParams {
  name: string;
  temperature_K: number;        // Kelvin
  pressure_kPa: number;         // kPa
  toxicGasDensity_kgm3: number; // kg/m³
  toxicGasType: 'CO2' | 'CH4' | 'SO2' | 'NH3' | 'H2S';
  waterVolume_m3: number;       // m³
  waterPH: number;              // 0-14
  waterTemp_K: number;          // Kelvin
  soilMoisture_kgkg: number;    // kg/kg (mass fraction)
  soilDensity_kgm3: number;     // kg/m³
}

export interface AIScore {
  habitabilityScore: number;    // 0-100%
  scores: {
    temperature_K: number;
    pressure_kPa: number;
    toxicGasDensity_kgm3: number;
    waterVolume_m3: number;
    waterPH: number;
    waterTemp_K: number;
    soilMoisture_kgkg: number;
    soilDensity_kgm3: number;
  };
  issues: Issue[];
}

export interface Issue {
  parameter: string;
  value: number;
  idealMin: number;
  idealMax: number;
  severity: 'critical' | 'warning' | 'mild';
  unit: string;
  label: string;
}

export type CapsuleMode = 'economic' | 'sustainable' | 'rapid';

export interface CapsuleDesign {
  mode: CapsuleMode;
  title: string;
  formType: 'aerodynamic' | 'spherical' | 'dome' | 'telescopic' | 'modular';
  armorType: string;
  description: string;
  features: string[];
  costSavings: number;        // % savings
  setupTime_s: number;        // seconds
  sustainabilityNotes: string;
}

export interface PlanetRecord {
  id: string;
  params: PlanetParams;
  aiScore: AIScore;
  capsules: Record<CapsuleMode, CapsuleDesign>;
  createdAt: Date;
}
